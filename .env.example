# URL the SvelteKit server uses to reach the lq-ai api (compose service name in Docker).
LQ_API_INTERNAL_URL=http://localhost:8000

# In Docker Compose the SvelteKit server reaches the api by service name:
#   LQ_API_INTERNAL_URL=http://api:8000
# adapter-node needs ORIGIN set so POST form actions aren't rejected in prod:
#   ORIGIN=http://localhost:3000
# Optional heavy services live behind profiles in vendor/lq-ai/docker-compose.yml: ollama, paddleocr, bridges.
# lq-ai's `web` service (OpenWebUI) maps to host port 3000 by default; redirect it to
# avoid colliding with donna-web (which also binds port 3000):
#   WEB_HOST_PORT=13000

# Playwright e2e (run against a live stack with a bootstrapped, password-rotated lq-ai account):
#   DONNA_BASE_URL=http://localhost:3000
#   DONNA_E2E_EMAIL=admin@example.com
#   DONNA_E2E_PASSWORD=...
