# Donna environment template. Copy to .env and fill in. The .env file is gitignored.
#
# Donna bundles the lq-ai backend and runs as its own Docker Compose project
# ("donna"). To run ALONGSIDE a separate lq-ai dev stack on the default ports,
# every host port below is shifted. Pick a free range on your machine.

# --- Host ports for Donna's stack (shift to avoid colliding with other stacks) ---
POSTGRES_HOST_PORT=25432
REDIS_HOST_PORT=26379
MINIO_API_HOST_PORT=29000
MINIO_CONSOLE_HOST_PORT=29001
GATEWAY_HOST_PORT=18001
API_HOST_PORT=18000
WEB_HOST_PORT=13000          # lq-ai's own web (NOT started by Donna) — parked off 3000
DONNA_WEB_HOST_PORT=13002    # Donna's frontend

# adapter-node Origin check — MUST equal the host URL the browser uses for donna-web.
ORIGIN=http://localhost:13002

# Frontend → api URL. In Docker the SvelteKit server reaches the api by service name.
# (Default in the compose env is http://api:8000; for host-run `npm run dev` use the
#  shifted api host port, e.g. http://localhost:18000.)
LQ_API_INTERNAL_URL=http://api:8000

# --- Required backend secrets (no defaults; bring-up FAILS if unset). Dev values OK locally. ---
POSTGRES_DB=lq_ai
POSTGRES_USER=lq_ai
POSTGRES_PASSWORD=change-me
MINIO_ROOT_USER=lq_ai
MINIO_ROOT_PASSWORD=change-me-min-8-chars
S3_ACCESS_KEY=lq_ai
S3_SECRET_KEY=change-me-min-8-chars        # match MINIO_ROOT_PASSWORD
LQ_AI_GATEWAY_KEY=change-me                # shared secret between api and gateway
JWT_SECRET=change-me-long-random-string

# Optional cloud provider keys (NOT needed for login/chat-create; only for inference):
#   ANTHROPIC_API_KEY=  OPENAI_API_KEY=

# --- Playwright e2e (needs the stack up + a login-ready admin; see README) ---
DONNA_BASE_URL=http://localhost:13002
DONNA_E2E_EMAIL=admin@lq.ai
DONNA_E2E_PASSWORD=change-me-min-12-chars
