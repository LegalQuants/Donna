{
	"name": "donna-desktop",
	"version": "0.1.0",
	"description": "Donna for Mac — desktop launcher for the Donna release stack",
	"author": "Kevin Keller",
	"license": "Apache-2.0",
	"main": "out/main/index.js",
	"type": "module",
	"scripts": {
		"dev": "electron-vite dev",
