{
	"name": "donna",
	"private": true,
	"version": "0.0.1",
	"license": "Apache-2.0",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:e2e": "playwright install && playwright test",
		"gen:api": "node scripts/sanitize-openapi.js vendor/lq-ai/docs/api/backend-openapi.yaml /tmp/donna-backend-openapi.yaml && openapi-typescript /tmp/donna-backend-openapi.yaml -o src/lib/api/backend.d.ts && node scripts/sanitize-openapi.js vendor/lq-ai/docs/api/gateway-openapi.yaml /tmp/donna-gateway-openapi.yaml && openapi-typescript /tmp/donna-gateway-openapi.yaml -o src/lib/api/gateway.d.ts"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.4",
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.59.1",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.2.2",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/svelte": "^5.3.1",
		"@testing-library/user-event": "^14.6.1",
		"@types/markdown-it": "^14.1.2",
		"@types/node": "^22",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^17.4.0",
		"jsdom": "^29.1.1",
		"openapi-typescript": "^7.13.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"tailwindcss": "^4.2.2",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.1",
		"vite": "^8.0.7",
		"vitest": "^4.1.3"
	},
	"dependencies": {
		"@lucide/svelte": "^1.16.0",
		"@mdit/plugin-katex": "^0.25.2",
		"@sveltejs/adapter-node": "^5.5.4",
		"bits-ui": "^2.18.1",
		"isomorphic-dompurify": "^3.14.0",
		"katex": "^0.17.0",
		"markdown-it": "^14.2.0",
		"pdfjs-dist": "^5.7.284"
	}
}
